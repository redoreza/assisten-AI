# === API Keys ===
# Required for Phase 1 (chat via Groq Llama 3.3 70B)
GROQ_API_KEY=gsk_replace_me

# Required for Phase 5 (RAG / embeddings)
VOYAGE_API_KEY=pa-replace_me

# Optional backup LLM (Phase 6+)
GEMINI_API_KEY=

# Tavily web search for LLM tool calling (1000 req/month free)
TAVILY_API_KEY=tvly-dev-replace_me

# NVIDIA NIM (build.nvidia.com) — primary provider when set, first in rotation
# Get from https://build.nvidia.com → user menu → API Keys (free, sign-up via Google/email).
NVIDIA_API_KEY=
NVIDIA_MODEL=meta/llama-3.3-70b-instruct

# OpenRouter — backup LLM provider for round-robin with Groq (free tier models)
# Leave OPENROUTER_API_KEY empty to use Groq only.
OPENROUTER_API_KEY=
OPENROUTER_MODEL=openai/gpt-oss-120b:free

# === Model Selection ===
LLM_MODEL=llama-3.3-70b-versatile
STT_MODEL=whisper-large-v3-turbo
EMBEDDING_MODEL=voyage-multilingual-2
TTS_VOICE_DEFAULT=id-ID-GadisNeural

# === Backend ===
HOST=127.0.0.1
PORT=8000
CORS_ORIGINS=http://localhost:3000
LOG_LEVEL=INFO

# === Storage Paths (relative to project root) ===
SQLITE_PATH=./data/sqlite/app.db
CHROMA_PATH=./data/chroma
PERSONAS_DIR=./data/personas
KB_DIR=./data/knowledge_base

# === Defaults ===
DEFAULT_PERSONA=pointer
DEFAULT_MODE=companion

# === RAG (Phase 5) ===
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=50
RAG_TOP_K=3
RAG_MIN_SIMILARITY=0.65

# === Memory ===
MEMORY_MAX_TURNS=10
